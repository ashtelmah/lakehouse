{
  "name": "Himalia",
  "config": {
    "connector.class": "io.debezium.connector.sqlserver.SqlServerConnector",
    "tasks.max": "1",

    "database.hostname": "HQ01DB02.or.nt",
    "database.port": "1433",
    "database.user": "dpl",
    "database.password": "StartSQL!",
    "database.names": "DataPlatform",

    "topic.prefix": "_",

    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",

    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",

    "table.include.list": "dbo.Products,dbo.Programs,dbo.PaymentPeriods,dbo.PlanedPayments,dbo.RealPayments,dbo.PlanedToRealPayments",

    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "schema-changes.mssql",

    "signal.data.collection": "dbo.DebeziumSignal",

    "tombstones.on.delete": "false",
    "delete.handling.mode": "rewrite",

    "heartbeat.interval.ms": "5000",
    "heartbeat.topics.prefix": "heartbeat",

    "database.encrypt": "false",
    "database.trustServerCertificate": "true",

    "snapshot.mode": "initial"
  }
}
